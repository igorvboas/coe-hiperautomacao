NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_PROJECT_REF=your-project-ref-here

# Necessário apenas para `npm run gen:types` (gerar types do schema).
# Obtém em: Supabase Studio → Account → Access Tokens → Generate new token
# SUPABASE_ACCESS_TOKEN=

# Phase 7.5 — Hardening de Segurança MVP
# ----------------------------------------

# Cloudflare Turnstile — captcha invisível no formulário público /r/[slug]
# site key (public): cole no Vercel env como variable de prod e preview
# secret key: setar via `vercel env add TURNSTILE_SECRET_KEY production preview`
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Salt para hash de IP em public_form_submissions.
# Gerar com: openssl rand -hex 32
# Setar via: vercel env add IP_HASH_SALT production preview
IP_HASH_SALT=

# Phase 7.6 — Enriquecimento por IA das Oportunidades
# ----------------------------------------------------

# Service role key — bypassa RLS para o UPDATE pós-IA disparado via after()
# quando o usuário pode estar deslogado (formulário público /r/[slug]).
# Usado por serviceRoleClient() em lib/supabase/server.ts.
# Obter em: Supabase Dashboard → Project Settings → API → service_role (secret)
# NUNCA expor em código client-side. NUNCA commitar valor real.
# Setar via: vercel env add SUPABASE_SERVICE_ROLE_KEY production preview
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API key — usada para gerar automaticamente os campos de Automação
# (ferramenta, escopo_automacao, beneficios_esperados, observacao, risco) e
# Priorização (esforco, complexidade, tempo, objetivo/alinhamento estratégico)
# a partir do conteúdo do formulário submetido pelo usuário.
# Obter em: https://platform.openai.com/api-keys
# Setar via: vercel env add OPENAI_API_KEY production preview
OPENAI_API_KEY=
