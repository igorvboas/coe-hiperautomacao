{
  "name": "coe-hiperautomacao",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "gen:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > lib/database.types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run tests/security",
    "test:ci": "vitest run --reporter=verbose --coverage",
    "audit:headers": "bash scripts/security/check-headers.sh",
    "audit:secrets": "bash scripts/security/audit-service-role.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "botid": "^1.5.11",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.0",
    "dotenv": "^16.4.5",
    "supabase": "^2.101.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.0"
  }
}
