# ============================================================
# .env.test — copie este arquivo para .env.test e preencha
# ============================================================
# IMPORTANTE: NUNCA aponte para projeto de produção. Se NEXT_PUBLIC_SUPABASE_URL
# não começar com http://127.0.0.1 ou um host explicitamente de teste,
# tests/setup/global-setup.ts aborta.

# Local Supabase via `supabase start`. Obter chaves com `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Hash salt — qualquer valor para testes (não é secret aqui).
IP_HASH_SALT=test-salt-only-for-vitest

# Turnstile test keys (Cloudflare publica pares "always pass" — confirmar via dashboard)
# site key sempre-pass: 1x00000000000000000000AA
# secret sempre-pass:   1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
